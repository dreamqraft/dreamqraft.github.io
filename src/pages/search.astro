---
import BaseLayout from "../layouts/BaseLayout.astro";
import { url } from "../consts";

const indexUrl = url("/search-index.json");
---

<BaseLayout title="Search" description="블로그 글 검색">
  <section class="archive-header">
    <p class="archive-kicker">Search</p>
    <h1>글 검색</h1>
    <p class="archive-description">제목, 본문, 태그, 카테고리에서 찾습니다.</p>
  </section>

  <div class="search-box">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"></circle>
      <path d="m20 20-3.5-3.5"></path>
    </svg>
    <input
      id="search-input"
      type="search"
      placeholder="검색어를 입력하세요…"
      autocomplete="off"
      autofocus
      aria-label="검색어"
    />
  </div>

  <p id="search-status" class="search-status" role="status"></p>
  <ul id="search-results" class="post-list"></ul>
</BaseLayout>

<script is:inline define:vars={{ indexUrl }}>
  const input = document.getElementById("search-input");
  const list = document.getElementById("search-results");
  const status = document.getElementById("search-status");
  let index = null;
  let loading = null;

  function loadIndex() {
    if (!loading) {
      loading = fetch(indexUrl)
        .then((r) => r.json())
        .then((data) => (index = data))
        .catch(() => {
          status.textContent = "검색 인덱스를 불러오지 못했습니다. 새로고침 후 다시 시도해주세요.";
        });
    }
    return loading;
  }

  function escapeHtml(s) {
    return s.replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]);
  }

  function escapeRegExp(s) {
    return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  }

  function highlight(text, tokens) {
    const pattern = new RegExp("(" + tokens.map(escapeRegExp).join("|") + ")", "gi");
    return escapeHtml(text).replace(pattern, "<mark>$1</mark>");
  }

  function snippet(body, tokens, width) {
    const lower = body.toLowerCase();
    let pos = -1;
    for (const t of tokens) {
      pos = lower.indexOf(t);
      if (pos !== -1) break;
    }
    if (pos === -1) return body.slice(0, width) + (body.length > width ? "…" : "");
    const start = Math.max(0, pos - Math.floor(width / 3));
    const end = Math.min(body.length, start + width);
    return (start > 0 ? "…" : "") + body.slice(start, end) + (end < body.length ? "…" : "");
  }

  function search(query) {
    const tokens = query.toLowerCase().split(/\s+/).filter(Boolean);
    if (tokens.length === 0) return [];
    const scored = [];
    for (const post of index) {
      const title = post.title.toLowerCase();
      const desc = post.description.toLowerCase();
      const tags = post.tags.join(" ").toLowerCase();
      const cat = (post.category + " " + post.categoryName).toLowerCase();
      const body = post.body.toLowerCase();
      let score = 0;
      let matchedAll = true;
      for (const t of tokens) {
        let s = 0;
        if (title.includes(t)) s += 5;
        if (tags.includes(t)) s += 3;
        if (desc.includes(t)) s += 2;
        if (cat.includes(t)) s += 2;
        if (body.includes(t)) s += 1;
        if (s === 0) {
          matchedAll = false;
          break;
        }
        score += s;
      }
      if (matchedAll) scored.push({ post, score });
    }
    scored.sort((a, b) => b.score - a.score);
    return scored.map((s) => s.post);
  }

  function render(query) {
    const q = query.trim();
    if (!q) {
      list.innerHTML = "";
      status.textContent = "";
      return;
    }
    const tokens = q.toLowerCase().split(/\s+/).filter(Boolean);
    const results = search(q);
    status.textContent = results.length
      ? `${results.length}개의 글을 찾았습니다.`
      : "검색 결과가 없습니다.";
    list.innerHTML = results
      .slice(0, 50)
      .map(
        (post) => `
      <li class="post-card">
        <div class="post-card-meta">
          <span class="post-card-category">${escapeHtml(post.categoryName)}</span>
          <time datetime="${post.date}">${post.date}</time>
        </div>
        <h2 class="post-card-title"><a href="${post.url}">${highlight(post.title, tokens)}</a></h2>
        <p class="post-card-excerpt">${highlight(snippet(post.body, tokens, 160), tokens)}</p>
      </li>`
      )
      .join("");
  }

  let timer;
  input.addEventListener("input", async () => {
    await loadIndex();
    clearTimeout(timer);
    timer = setTimeout(() => {
      render(input.value);
      const params = new URLSearchParams(location.search);
      if (input.value.trim()) params.set("q", input.value.trim());
      else params.delete("q");
      history.replaceState(null, "", params.size ? `?${params}` : location.pathname);
    }, 120);
  });

  // ?q= 파라미터로 진입한 경우 바로 검색
  const initial = new URLSearchParams(location.search).get("q");
  if (initial) {
    input.value = initial;
    loadIndex().then(() => render(initial));
  }
</script>
