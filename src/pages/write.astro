---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CATEGORIES, GITHUB } from "../consts";

const categories = CATEGORIES.map((c) => ({ slug: c.slug, name: c.name }));
const github = GITHUB;
---

<BaseLayout title="Write" description="새 글 작성" noindex>
  <section class="archive-header">
    <p class="archive-kicker">Write</p>
    <h1>새 글 쓰기</h1>
    <p class="archive-description">
      작성한 내용이 GitHub 커밋 화면으로 전달됩니다. 커밋하면 1~2분 안에 자동 배포됩니다.
      (저장소 쓰기 권한이 있는 계정으로 GitHub에 로그인되어 있어야 합니다.)
    </p>
  </section>

  <form id="write-form" class="write-form">
    <div class="field-row">
      <label class="field">
        <span>종류</span>
        <select id="w-type">
          <option value="blog">블로그 글 (공개)</option>
          <option value="journal">투자 저널 (비공개)</option>
        </select>
      </label>
      <label class="field">
        <span>날짜</span>
        <input id="w-date" type="date" required />
      </label>
    </div>

    <label class="field">
      <span>제목</span>
      <input id="w-title" type="text" placeholder="글 제목" required />
    </label>

    <div id="blog-only">
      <label class="field">
        <span>요약 (description) — 검색 결과와 목록에 표시됩니다</span>
        <input id="w-description" type="text" placeholder="한 줄 요약" />
      </label>
      <div class="field-row">
        <label class="field">
          <span>카테고리</span>
          <select id="w-category">
            {categories.map((c) => <option value={c.slug}>{c.name}</option>)}
          </select>
        </label>
        <label class="field">
          <span>슬러그 (URL, 영문 권장)</span>
          <input id="w-slug" type="text" placeholder="my-post-slug" pattern="[a-z0-9\-]*" />
        </label>
      </div>
    </div>

    <label class="field">
      <span>태그 (쉼표로 구분)</span>
      <input id="w-tags" type="text" placeholder="ETF, 자산배분" />
    </label>

    <label class="field">
      <span>본문 (마크다운)</span>
      <textarea id="w-body" rows="14" placeholder="본문을 마크다운으로 작성하세요…"></textarea>
    </label>

    <details class="write-preview">
      <summary>생성될 파일 미리보기</summary>
      <pre><code id="w-preview"></code></pre>
    </details>

    <div class="write-actions">
      <button type="submit" class="button-primary" id="w-github">GitHub에서 커밋하기 →</button>
      <button type="button" class="chip" id="w-copy">내용 복사</button>
      <span id="w-status" class="search-status"></span>
    </div>
    <p class="write-hint">
      본문이 아주 길면 브라우저 URL 한도 때문에 커밋 화면에 내용이 잘릴 수 있습니다. 그 경우
      "내용 복사"로 복사해 커밋 화면에 붙여넣으세요.
    </p>
  </form>
</BaseLayout>

<script is:inline define:vars={{ github }}>
  const $ = (id) => document.getElementById(id);
  const typeEl = $("w-type");
  const blogOnly = $("blog-only");

  // 오늘 날짜 기본값
  $("w-date").value = new Date().toISOString().split("T")[0];

  // URL로 종류 선택: /write/?type=journal
  const preset = new URLSearchParams(location.search).get("type");
  if (preset === "journal") typeEl.value = "journal";

  // 투자 저널 기본 템플릿 — 저널을 선택하면 빈 본문에 자동으로 채워집니다.
  const JOURNAL_TEMPLATE = [
    "## 시장 메모",
    "",
    "- ",
    "",
    "## 매매 기록 (없으면 삭제)",
    "",
    "| 항목 | 내용 |",
    "|------|------|",
    "| 무엇을 | |",
    "| 왜 지금 | |",
    "| 언제 파는가 (논리가 깨지는 조건) | |",
    "| 틀렸다는 신호 | |",
    "| 포트폴리오 내 역할 | |",
    "",
    "## 포트폴리오 현황",
    "",
    "- 주식 : 채권 : 현금 =  :  : ",
    "- 목표 대비 편차: ",
    "",
    "## 감정 상태",
    "",
    "- 지금 사고 싶은/팔고 싶은 충동이 있는가? 근거는 규칙인가 뉴스인가?",
    "",
    "## 다음 액션",
    "",
    "- ",
  ].join("\n");

  const bodyEl = $("w-body");
  function syncType() {
    const isJournal = typeEl.value === "journal";
    blogOnly.style.display = isJournal ? "none" : "";
    if (isJournal && !bodyEl.value.trim()) {
      bodyEl.value = JOURNAL_TEMPLATE;
    } else if (!isJournal && bodyEl.value === JOURNAL_TEMPLATE) {
      bodyEl.value = "";
    }
  }
  typeEl.addEventListener("change", () => {
    syncType();
    updatePreview();
  });
  syncType();

  function autoSlug(title) {
    const s = title
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, "")
      .trim()
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-");
    return s;
  }
  $("w-title").addEventListener("input", () => {
    if (!$("w-slug").dataset.touched) $("w-slug").value = autoSlug($("w-title").value);
  });
  $("w-slug").addEventListener("input", () => ($("w-slug").dataset.touched = "1"));

  function buildFile() {
    const type = typeEl.value;
    const title = $("w-title").value.trim();
    const date = $("w-date").value;
    const tags = $("w-tags")
      .value.split(",")
      .map((t) => t.trim())
      .filter(Boolean);
    const tagsYaml = `[${tags.join(", ")}]`;
    const body = $("w-body").value.trim();
    const esc = (s) => s.replace(/"/g, '\\"');

    let frontmatter;
    let filename;
    if (type === "blog") {
      const description = $("w-description").value.trim();
      const category = $("w-category").value;
      const slug = $("w-slug").value.trim() || date;
      frontmatter = [
        "---",
        `title: "${esc(title)}"`,
        `description: "${esc(description)}"`,
        `pubDate: ${date}`,
        `category: ${category}`,
        `tags: ${tagsYaml}`,
        "---",
      ].join("\n");
      filename = `src/content/blog/${slug}.md`;
    } else {
      const slug = `${date}-${autoSlug(title) || "entry"}`;
      frontmatter = [
        "---",
        `title: "${esc(title)}"`,
        `pubDate: ${date}`,
        `tags: ${tagsYaml}`,
        "---",
      ].join("\n");
      filename = `src/content/journal/${slug}.md`;
    }
    return { filename, content: `${frontmatter}\n\n${body}\n` };
  }

  function updatePreview() {
    const { filename, content } = buildFile();
    $("w-preview").textContent = `# ${filename}\n\n${content}`;
  }
  document.getElementById("write-form").addEventListener("input", updatePreview);
  updatePreview();

  document.getElementById("write-form").addEventListener("submit", (ev) => {
    ev.preventDefault();
    const { filename, content } = buildFile();
    const url =
      `https://github.com/${github.repo}/new/${github.branch}` +
      `?filename=${encodeURIComponent(filename)}&value=${encodeURIComponent(content)}`;
    window.open(url, "_blank");
    $("w-status").textContent = "GitHub 커밋 화면을 새 탭에서 열었습니다.";
  });

  $("w-copy").addEventListener("click", async () => {
    const { content } = buildFile();
    await navigator.clipboard.writeText(content);
    $("w-status").textContent = "파일 내용을 복사했습니다.";
  });
</script>
